{% extends '@EasyAdmin/crud/index.html.twig' %}

{% block main %}
    {% for restaurantName, menus in groupedMenus %}
        <h2 class="mt-4 mb-3">{{ restaurantName }}</h2>
        
        <div class="row">
            {% for menu in menus %}
                <div class="col-md-3 mb-4">
                    <div class="card shadow-sm" style="border-radius: 15px; border: 1px solid #ddd; min-height: 300px;">
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title"><strong>{{ menu.name }}</strong></h5>
                            <div class="card-text text-muted flex-grow-1">
                                {{ menu.description|raw }}
                            </div>
                            
                            <div class="mt-3">
                                <a href="{{ ea_url()
                                    .setController('App\\Controller\\Admin\\PlateCrudController')
                                    .setAction('index')
                                    .set('menu_id', menu.id) }}
                                    .generateUrl() }}" 
                                   class="btn btn-primary">
                                   link to viewplate of this menu
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endfor %}

    {% if groupedMenus is empty %}
        <div class="text-center p-5 text-muted">No menus found.</div>
    {% endif %}
{% endblock %}