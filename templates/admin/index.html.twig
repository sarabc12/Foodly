{% extends '@EasyAdmin/layout.html.twig' %}
{% block body_javascript %}
    {{ parent() }}
    <script type="module">
        import '{{ asset('stimulus_bootstrap') }}';
    </script>
{% endblock %}

{% block main %}
    <div class="content-panel">
        <div class="content-panel-body with-background shadow-sm" style="border-radius: 10px; padding: 20px;">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div>
                    <h2 class="h4 m-0">Order Rate</h2>
                </div>
            </div>
            <div style="height: 400px; width: 100%;">
                {{ render_chart(chart) }}
            </div>
        </div>
    </div>
{% endblock %}

